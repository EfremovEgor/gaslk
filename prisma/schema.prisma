generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  pending
  confirmed
  shipped
  delivered
  cancelled
  completed
}

model Order {
  id                  String      @id
  createdAt           DateTime    @default(now())
  status              OrderStatus @default(pending)
  desiredDeliveryDate DateTime
  deliveryAddress     String
  amount              Float
  user                User        @relation(fields: [userId], references: [id])
  userId              String
  contactFirstName    String
  contactPhone        String

  @@map("orders")
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String
  firstName   String?
  lastName    String?
  middleName  String?
  phoneNumber String?
  addresses   Address[]
  orders      Order[]
  locked      Boolean   @default(false)

  @@map("users")
}

model Address {
  id      String @id @default(uuid())
  user    User   @relation(fields: [userId], references: [id])
  userId  String
  address String

  @@map("addresses")
}
